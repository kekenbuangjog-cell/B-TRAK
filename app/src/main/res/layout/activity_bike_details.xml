<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/industrial_input"
            android:backgroundTint="@color/industrial_surface"
            android:padding="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">

            <View
                android:layout_width="4dp"
                android:layout_height="24dp"
                android:background="@color/industrial_orange"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="B-TRAK"
                    android:textColor="@color/industrial_orange"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STATION: BICYCLE DETAILS"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="10sp"
                    android:fontFamily="monospace"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginBottom="32dp">

            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/logo_placeholder"
                android:padding="16dp"
                android:background="@drawable/industrial_input"
                android:backgroundTint="@color/industrial_surface"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/detail_bike_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SPANKER R1"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="24sp"
                android:fontFamily="monospace"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/detail_bike_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Road Bike"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="12sp"
                android:fontFamily="monospace"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/industrial_input"
            android:padding="20dp"
            android:orientation="vertical"
            android:layout_marginBottom="24dp"
            android:backgroundTint="@color/industrial_surface">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ODOMETER_LOG"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="11sp"
                android:fontFamily="monospace"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom">

                <TextView
                    android:id="@+id/detail_total_km"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.0"
                    android:textColor="@color/industrial_orange"
                    android:textSize="32sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" KM"
                    android:textColor="@color/industrial_orange"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="6dp"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/scuffed_metal"
                android:layout_marginVertical="16dp"/>

            <Button
                android:id="@+id/btn_update_odometer"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="START RECORDING"
                android:backgroundTint="@color/industrial_orange"
                android:textColor="@color/industrial_surface"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:stateListAnimator="@null"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CONSUMABLE_COMPONENTS"
            android:textColor="@color/industrial_orange"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:id="@+id/consumables_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="32dp">
            
            <include 
                android:id="@+id/consumable_chain"
                layout="@layout/item_consumable" />
            
            <include 
                android:id="@+id/consumable_front_tire"
                layout="@layout/item_consumable" />
            
            <include 
                android:id="@+id/consumable_rear_tire"
                layout="@layout/item_consumable" />
            
            <include 
                android:id="@+id/consumable_front_brake"
                layout="@layout/item_consumable" />
            
            <include 
                android:id="@+id/consumable_rear_brake"
                layout="@layout/item_consumable" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>