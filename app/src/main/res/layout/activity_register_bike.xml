<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/industrial_input"
            android:backgroundTint="#1A1A1A"
            android:padding="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="40dp">

            <View
                android:layout_width="4dp"
                android:layout_height="24dp"
                android:background="@color/industrial_orange"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="B-TRAK"
                    android:textColor="@color/industrial_orange"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STATION: NEW REGISTRATION"
                    android:textColor="@color/workshop_white"
                    android:textSize="10sp"
                    android:fontFamily="monospace"/>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bicycle Name"
            android:textColor="@color/galvanized_steel"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp"/>

        <EditText
            android:id="@+id/edit_bike_name"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/industrial_input"
            android:hint="Enter name (e.g. Mamachari bike)"
            android:textColorHint="#444444"
            android:textColor="@color/workshop_white"
            android:fontFamily="monospace"
            android:paddingStart="16dp"
            android:layout_marginBottom="24dp"
            android:inputType="textCapCharacters"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bicycle Type"
            android:textColor="@color/galvanized_steel"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp"/>

        <Spinner
            android:id="@+id/spinner_bike_type"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/industrial_input"
            android:paddingStart="16dp"
            android:layout_marginBottom="48dp"
            android:entries="@array/bike_types"
            android:spinnerMode="dropdown"/>

        <Button
            android:id="@+id/btn_add_to_garage"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="ADD TO GARAGE"
            android:backgroundTint="@color/industrial_orange"
            android:textColor="@color/industrial_black"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:stateListAnimator="@null"/>

    </LinearLayout>
</ScrollView>