<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <FrameLayout
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:background="@drawable/industrial_input"
            android:padding="8dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/register_logo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/logo_placeholder"
                android:scaleType="centerInside" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="B-TRAK"
            android:textColor="@color/industrial_orange"
            android:textSize="24sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create New Account"
            android:textColor="#F5F5F5"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="40dp"/>

        <EditText
            android:id="@+id/reg_user"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/industrial_input"
            android:hint="Username"
            android:textColorHint="#666666"
            android:textColor="#F5F5F5"
            android:fontFamily="monospace"
            android:paddingStart="16dp"
            android:layout_marginBottom="16dp"
            android:inputType="text"/>

        <EditText
            android:id="@+id/reg_email"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/industrial_input"
            android:hint="Email Address"
            android:textColorHint="#666666"
            android:textColor="#F5F5F5"
            android:fontFamily="monospace"
            android:paddingStart="16dp"
            android:layout_marginBottom="16dp"
            android:inputType="textEmailAddress"/>

        <EditText
            android:id="@+id/reg_pass"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/industrial_input"
            android:hint="Password"
            android:textColorHint="#666666"
            android:textColor="#F5F5F5"
            android:fontFamily="monospace"
            android:paddingStart="16dp"
            android:layout_marginBottom="16dp"
            android:inputType="textPassword"/>

        <EditText
            android:id="@+id/reg_confirm_pass"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/industrial_input"
            android:hint="Confirm Password"
            android:textColorHint="#666666"
            android:textColor="#F5F5F5"
            android:fontFamily="monospace"
            android:paddingStart="16dp"
            android:layout_marginBottom="32dp"
            android:inputType="textPassword"/>

        <Button
            android:id="@+id/btn_register_account"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:backgroundTint="@color/industrial_orange"
            android:text="Create Account"
            android:textColor="@color/industrial_black"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:stateListAnimator="@null"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ALREADY REGISTERED?"
                android:textColor="@color/galvanized_steel"
                android:textSize="12sp"
                android:fontFamily="monospace"/>

            <TextView
                android:id="@+id/text_back_to_login"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" [ LOGIN HERE ]"
                android:textColor="@color/industrial_orange"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>