<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/industrial_input"
            android:backgroundTint="@color/industrial_surface"
            android:padding="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">

            <View
                android:layout_width="4dp"
                android:layout_height="24dp"
                android:background="@color/industrial_orange"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="B-TRAK"
                    android:textColor="@color/industrial_orange"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Station: My Garage"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="10sp"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <ImageView
                android:id="@+id/btn_settings"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_gear"
                android:contentDescription="Settings"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="?android:attr/textColorPrimary"
                android:layout_marginEnd="16dp"/>

            <ImageView
                android:id="@+id/btn_quit"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_lock_power_off"
                android:contentDescription="Quit App"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/industrial_orange" />

        </LinearLayout>



        <LinearLayout
            android:id="@+id/box_add_bike"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:background="@drawable/industrial_input"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="32dp"
            android:clickable="true"
            android:focusable="true"
            android:backgroundTint="@color/industrial_surface">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+"
                android:textColor="@color/industrial_orange"
                android:textSize="48sp"
                android:fontFamily="monospace"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="[ REGISTER NEW BIKE ]"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="12sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="My BICYCLES"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_garage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />


    </LinearLayout>
</androidx.core.widget.NestedScrollView>