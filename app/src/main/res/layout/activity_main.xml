<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/industrial_input"
            android:backgroundTint="#1A1A1A"
            android:padding="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">

            <View
                android:layout_width="4dp"
                android:layout_height="24dp"
                android:background="@color/industrial_orange"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="B-TRAK"
                    android:textColor="@color/industrial_orange"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Station: My Garage"
                    android:textColor="@color/galvanized_steel"
                    android:textSize="10sp"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <ImageView
                android:id="@+id/btn_settings"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_gear"
                android:contentDescription="Settings"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginEnd="16dp"/>

            <ImageView
                android:id="@+id/btn_quit"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_lock_power_off"
                android:contentDescription="Quit App"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/industrial_orange" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/box_add_bike"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:background="@drawable/industrial_input"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="32dp"
            android:clickable="true"
            android:focusable="true"
            android:backgroundTint="#1A1A1A">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+"
                android:textColor="@color/industrial_orange"
                android:textSize="48sp"
                android:fontFamily="monospace"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="[ REGISTER NEW BIKE ]"
                android:textColor="@color/workshop_white"
                android:textSize="12sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="My BICYCLES"
            android:textColor="@color/workshop_white"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/industrial_input"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/logo_placeholder"
                android:padding="8dp"
                android:background="#222222"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SampleBike"
                    android:textColor="@color/workshop_white"
                    android:textSize="16sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TYPE: ROAD_AERO"
                    android:textColor="@color/galvanized_steel"
                    android:textSize="10sp"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <TextView
                android:id="@+id/text_bike_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="[ READY TO RIDE ]"
                android:textColor="@color/industrial_orange"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:background="@drawable/industrial_input"
                android:backgroundTint="#252525"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>