<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground"
    android:fillViewport="true">

        <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/industrial_input"
            android:backgroundTint="@color/industrial_surface"
            android:padding="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">

            <View
                android:layout_width="4dp"
                android:layout_height="24dp"
                android:background="@color/industrial_orange"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="B-TRAK"
                    android:textColor="@color/industrial_orange"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Station: Settings"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="10sp"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_revert"
                android:contentDescription="Back"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="?android:attr/textColorPrimary" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="User Profile"
            android:textColor="@color/industrial_orange"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/industrial_input"
            android:backgroundTint="@color/industrial_surface"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UserMe"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="16sp"
                android:fontFamily="monospace"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="kein.ivan@example.com"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="11sp"
                android:fontFamily="monospace"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="App Preferences"
            android:textColor="@color/industrial_orange"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/industrial_input"
            android:backgroundTint="@color/industrial_surface"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Distance Units (KM)"
                    android:textColor="?android:attr/textColorPrimary"
                    android:fontFamily="monospace"/>
                <Switch
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:checked="true"
                    android:thumbTint="@color/industrial_orange"
                    android:trackTint="@color/scuffed_metal"/>
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dark Mode"
                    android:textColor="?android:attr/textColorPrimary"
                    android:fontFamily="monospace"/>
                <Switch
                    android:id="@+id/switch_dark_mode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:checked="true"
                    android:clickable="true"
                    android:focusable="true"
                    android:thumbTint="@color/industrial_orange"
                    android:trackTint="@color/switch_track"/>
            </RelativeLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Integrations"
            android:textColor="@color/industrial_orange"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp"/>

        <Button
            android:id="@+id/btn_strava_sync"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="32dp"
            android:backgroundTint="#FC4C02"
            android:fontFamily="monospace"
            android:stateListAnimator="@null"
            android:text="Link Strava Account /GPS Services for not Prototype Running"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="B-TRAK Version 1.0.0 (Alpha)"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btn_logout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Logout Session"
            android:backgroundTint="@color/industrial_destructive_bg"
            android:textColor="#FF4444"
            android:fontFamily="monospace"
            android:stateListAnimator="@null"/>

    </LinearLayout>
</ScrollView>